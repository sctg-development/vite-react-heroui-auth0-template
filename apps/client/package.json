{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:env": "bash -c 'set -a && source ../../.env && set +a && vite'",
    "build": "yarn clean && tsc && vite build",
    "build:env": "bash -c 'yarn clean && set -a && source ../../.env && set +a && tsc && vite build \"$@\"' --",
    "lint": "eslint ./src/**/**/*.{ts,tsx} --fix",
    "type-check": "tsc --noEmit",
    "preview:env": "bash ./scripts/preview-ensure.sh",
    "clean": "rm -rf dist .turbo node_modules/.vite node_modules/.cache",
    "update:heroui:cli": "npx heroui-cli@latest upgrade --all",
    "update:heroui": "node --no-warnings --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"));' ./update-heroui.ts",
    "openapi": "node --experimental-strip-types get-openapi.ts"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.15.0",
    "@heroui/button": "^2.2.31",
    "@heroui/chip": "^2.2.24",
    "@heroui/code": "^2.2.24",
    "@heroui/date-picker": "^2.3.32",
    "@heroui/dropdown": "^2.3.31",
    "@heroui/image": "^2.2.19",
    "@heroui/input": "^2.4.32",
    "@heroui/kbd": "^2.2.25",
    "@heroui/link": "^2.2.25",
    "@heroui/modal": "^2.2.28",
    "@heroui/navbar": "^2.2.29",
    "@heroui/number-input": "^2.0.22",
    "@heroui/pagination": "^2.2.26",
    "@heroui/scroll-shadow": "^2.3.19",
    "@heroui/shared-utils": "^2.1.12",
    "@heroui/snippet": "^2.2.32",
    "@heroui/switch": "^2.2.26",
    "@heroui/system": "^2.4.27",
    "@heroui/table": "^2.2.31",
    "@heroui/theme": "^2.4.26",
    "@heroui/toast": "^2.0.21",
    "@heroui/tooltip": "^2.2.28",
    "@react-aria/visually-hidden": "3.8.30",
    "@react-types/shared": "^3.33.0",
    "@tailwindcss/postcss": "^4.2.1",
    "framer-motion": "12.34.3",
    "i18next": "^25.8.13",
    "i18next-http-backend": "^3.0.2",
    "jose": "^6.1.3",
    "oidc-client-ts": "^3.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.1",
    "swagger-ui-react": "^5.32.0",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.2.1"
  },
  "devDependencies": {
    "@sctg/vite-plugin-github-pages-spa": "^0.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-jsdoc": "^6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "swagger-jsdoc": "^6.2.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
